{% extends 'layout.html.twig' %}

{% block title %}Orders{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1>Orders</h1>
        </div>

        <table class="table table-striped table-hover align-middle">
            <thead>
            <tr>
                <th>Order #</th>
                <th>Date</th>
                <th>Status</th>
                <th>Total Items</th>
                <th>Total Price</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for order in orders %}
                <tr>
                    <td><strong>#{{ order.id }}</strong></td>
                    <td>{{ order.createdAt | date('Y-m-d H:i') }}</td>
                    <td>
                        <span class="badge bg-success">{{ order.status.value | capitalize }}</span>
                    </td>
                    <td>
                        {% set total_qty = 0 %}
                        {% for item in order.items %}
                            {% set total_qty = total_qty + item.quantity %}
                        {% endfor %}
                        {{ total_qty }}
                    </td>
                    <td><strong class="text-success">${{ order.totalPrice }}</strong></td>
                    <td>
                        <a href="{{ path('order_show', {id: order.id}) }}" class="btn btn-sm btn-info">View Details</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center py-4">No orders found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
