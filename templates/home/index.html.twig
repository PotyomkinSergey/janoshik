{% extends 'layout.html.twig' %}

{% block title %}Dashboard - Janoshik web store{% endblock %}

{% block body %}
    <div class="container mt-4">


        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for product in products %}
                <div class="col">
                    <div class="card h-100 shadow-sm position-relative">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">
                                    <a href="{{ path('product_show', {id: product.id}) }}" class="text-decoration-none text-dark stretched-link">
                                        {{ product.name }}
                                    </a>
                                </h5>
                                <span class="badge {{ product.stock > 0 ? 'bg-success' : 'bg-danger' }}">
                                    {{ product.stock > 0 ? product.stock ~ ' in stock' : 'Out of stock' }}
                                </span>
                            </div>
                            <p class="text-muted small flex-grow-1">
                                {{ product.description ? (product.description | slice(0, 150) ~ (product.description | length > 150 ? '...' : '')) : 'No description available.' }}
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-3" style="position: relative; z-index: 2;">
                                <span class="h5 mb-0 text-primary">${{ product.price }}</span>
                                <div class="d-flex gap-1">
                                    {% if product.stock > 0 %}
                                        <form method="post" action="{{ path('cart_add', {id: product.id}) }}" class="m-0">
                                            <button class="btn btn-sm btn-success">Add to Cart</button>
                                        </form>
                                    {% else %}
                                        <button class="btn btn-sm btn-secondary" disabled>Out of Stock</button>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center">
                    <div class="alert alert-info">No products found.</div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
